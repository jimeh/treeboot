{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "always-update": true,
  "include-component-in-tag": false,
  "include-v-in-tag": true,
  "draft": true,
  "force-tag-creation": true,
  "packages": {
    ".": {
      "package-name": "treeboot",
      "version-file": "Cargo.toml",
      "extra-files": [
        {
          "type": "toml",
          "path": "Cargo.lock",
          "jsonpath": "$.package[?(@.name.value == 'treeboot')].version"
        },
        {
          "type": "toml",
          "path": "Cargo.lock",
          "jsonpath": "$.package[?(@.name.value == 'treeboot-core')].version"
        },
        {
          "type": "toml",
          "path": "Cargo.lock",
          "jsonpath": "$.package[?(@.name.value == 'treeboot-release-helper')].version"
        }
      ]
    }
  }
}
